rules_version = '2';

// ─── CardDex Firebase Storage Security Rules ─────────────────────────────────
// Card assets (images + videos) live under: cards/{cardId}/card.jpg
//                                            cards/{cardId}/reveal.mp4
//
// Read:  any authenticated user (needed to display card images in the app)
// Write: admin only (custom claim { admin: true })
// ─────────────────────────────────────────────────────────────────────────────

service firebase.storage {
  match /b/{bucket}/o {

    // Card images and reveal videos
    match /cards/{cardId}/{fileName} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
        && request.auth.token.admin == true
        && (fileName == 'card.jpg'
            || fileName == 'card.png'
            || fileName == 'reveal.mp4')
        && request.resource.size < 200 * 1024 * 1024; // 200 MB max per file
    }

    // Deny everything else by default (no wildcard fallthrough)
    match /{allPaths=**} {
      allow read, write: if false;
    }

  }
}
