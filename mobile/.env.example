# CardDex Mobile — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.production and fill in your real Firebase credentials.
# Local dev uses the emulator automatically — no credentials needed.
#
# Get these from: Firebase Console → Project Settings → Your Apps → Web App
# ─────────────────────────────────────────────────────────────────────────────

# Optional (dev only): set to true to connect to local Firebase emulators.
EXPO_PUBLIC_USE_FIREBASE_EMULATORS=false

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
