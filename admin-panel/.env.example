# CardDex Admin Panel — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local (or .env.production) and fill in your Firebase credentials.
# By default (even in local dev), the admin panel talks to real Firebase.
# To use emulators locally instead, set: REACT_APP_USE_FIREBASE_EMULATORS=true
#
# Get these from: Firebase Console → Project Settings → Your Apps → Web App
# ─────────────────────────────────────────────────────────────────────────────

REACT_APP_FIREBASE_API_KEY=
REACT_APP_FIREBASE_AUTH_DOMAIN=
REACT_APP_FIREBASE_PROJECT_ID=
REACT_APP_FIREBASE_STORAGE_BUCKET=
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=
REACT_APP_FIREBASE_APP_ID=

# Optional: use Firebase emulators in local development
REACT_APP_USE_FIREBASE_EMULATORS=false

# Optional: pre-configure Gemini API key for AI video generation (Veo)
# Get a key at https://aistudio.google.com/app/apikey
# If set, the "Generate with AI" button works without visiting AI Settings.
REACT_APP_GEMINI_API_KEY=
